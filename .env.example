# Clé secrète créée dans le tableau de bord OpenAI.
# Ne jamais utiliser le préfixe NEXT_PUBLIC_ et ne jamais committer une vraie clé.
OPENAI_API_KEY=

# Optionnel : permet de changer de modèle sans modifier le code.
# Le modèle économique validé par défaut est figé dans la route serveur.
OPENAI_OCR_MODEL=gpt-5.4-mini-2026-03-17
